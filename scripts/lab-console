#!/usr/bin/env bash
# Lateral Movement Lab — launcher (single environment).
# Brings the two-segment network up and logs you STRAIGHT into the attacker box
# (secutils) as a real interactive shell. From there you run the real tools —
# nmap / hydra / ssh / proxychains — and pivot through the workstation. No `docker`
# to memorise, but nothing is faked either: the shell, the tools and the errors
# are all genuine, which is exactly why an AI assistant can help you in it.
#
#   ./start.sh              bring the lab up and drop into the secutils shell
#   ./start.sh open juice   just open a browser target (Juice Shop :3000)
#   ./start.sh open dvwa    just open a browser target (DVWA :8080)
set -uo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LOG="$(mktemp -t lm-console.XXXXXX)"
# Real escape characters via $'...' so colours survive heredocs and plain echo
# (a bare '\033' string only works inside printf format strings). No colours
# when stdout isn't a terminal (piped output, CI).
if [ -t 1 ]; then
  C_T=$'\033[1;36m'; C_OK=$'\033[0;32m'; C_WARN=$'\033[1;33m'; C_ERR=$'\033[0;31m'
  C_D=$'\033[0;90m'; C_P=$'\033[1;35m'; NC=$'\033[0m'
else
  C_T=''; C_OK=''; C_WARN=''; C_ERR=''; C_D=''; C_P=''; NC=''
fi
ATTACKER="secutils"

banner(){ printf "${C_T}"; cat <<EOF

  +===================================================================+
  |        L A T E R A L   M O V E M E N T   ·   P I V O T I N G      |
  |        Attacker: secutils 172.20.1.10  ·  corp segment            |
  +===================================================================+
EOF
printf "${NC}\n"; }

need_docker(){ command -v docker >/dev/null 2>&1 || { printf "${C_ERR}Docker isn't installed.${NC}\n"; exit 1; }
  docker info >/dev/null 2>&1 || { printf "${C_ERR}Docker isn't running.${NC} Start Docker Desktop.\n"; exit 1; }; }

dc(){ ( cd "$ROOT" && docker compose "$@" ); }

bring_up(){
  if [ -n "$(dc ps -q 2>/dev/null)" ]; then printf "${C_OK}Lab already running.${NC}\n"; return; fi
  printf "${C_D}Powering on the lab network (first run pulls images)...${NC}\n"
  ( cd "$ROOT" && docker compose up -d ) >"$LOG" 2>&1 &
  local pid=$!; while kill -0 "$pid" 2>/dev/null; do printf "."; sleep 1; done; printf "\n"
  if ! wait "$pid"; then printf "${C_ERR}Could not start the lab:${NC}\n"; tail -n 15 "$LOG"; exit 1; fi
  printf "${C_OK}Network up. You are logged in.${NC}\n"
}

open_url(){ local u="${1:-}"; [ -n "$u" ] || { printf "${C_ERR}usage: open juice|dvwa${NC}\n"; return 1; }
  case "$u" in juice|juice-shop) u="http://localhost:3000" ;; dvwa) u="http://localhost:8080" ;; esac
  printf "${C_OK}Opening %s${NC}\n" "$u"
  if command -v open >/dev/null 2>&1; then open "$u" >/dev/null 2>&1
  elif command -v xdg-open >/dev/null 2>&1; then xdg-open "$u" >/dev/null 2>&1
  elif command -v explorer.exe >/dev/null 2>&1; then explorer.exe "$u" >/dev/null 2>&1
  else printf "${C_WARN}Open in your browser:${NC} %s\n" "$u"; fi; }

# Log the student straight into the secutils container as a real interactive shell.
# The welcome banner + themed prompt come from the image (/etc/bash/bashrc), so it
# feels like logging into a dedicated pentest workstation every time. The web
# targets are published to the host browser, so we just point at them here.
enter_shell(){
  printf "\n${C_OK}Connection established.${NC} Logging in to the %s attacker workstation...\n" "$ATTACKER"
  printf "${C_D}Browser targets on your host: Juice Shop http://localhost:3000 · DVWA http://localhost:8080${NC}\n"
  printf "${C_D}(open one without entering the shell: ./start.sh open juice | open dvwa)${NC}\n"
  printf "${C_D}Type 'exit' to leave the shell.${NC}\n\n"
  dc exec "$ATTACKER" bash 2>/dev/null || dc exec "$ATTACKER" sh 2>/dev/null \
    || { printf "${C_ERR}No shell on '%s'. Is the lab up?${NC}\n" "$ATTACKER"; return 1; }
  printf "\n"; read -r -p "Shut the lab down before leaving? (y/N) " a
  case "$a" in [Yy]*) dc down >/dev/null 2>&1; printf "${C_OK}Stopped.${NC}\n" ;;
               *) printf "${C_D}Left running. ./start.sh to return, or 'docker compose down' to halt it.${NC}\n" ;; esac
}

# `./start.sh open juice|dvwa` — open a browser target and exit, no shell.
if [ "${1:-}" = "open" ]; then need_docker; open_url "${2:-}"; exit $?; fi

banner; need_docker; bring_up; enter_shell
